//3.A circle utility should determine the area and circumference using a given radius. Model this using a class and suitable methods.
class Circule{
	void area(double r) {
		double area=Math.PI*r*r;
		System.out.println("Area is: "+ Math.round(area));
	}
	void circumference(double r) {
		double circum=2*(Math.PI)*r;
		System.out.println("Circumference is: "+ Math.round(circum));
	}
}
public class ClassObj_1 {

	public static void main(String[] args) {
Circule c=new Circule();
c.area(7);
c.circumference(7);
}
}

