//7.A banking system maintains an account with accountNumber, name, and balance, allowing deposit and withdrawal operations.
class HDFCBank{
	long acc_number;
	String name;
	double balance=50000;
	void withdraw(double amt) {
		if(balance>amt) {
			balance-=amt;
			System.out.println("Current balance: "+balance);
		}
		else {
			System.out.println("Insufficient balance");
		}
	}
	void deposit(double amt) {
		balance+=amt;
		System.out.println("Current balance : "+balance);
	}
	void check() {
		System.out.println("Your balance is: "+balance);
	}
}
public class ClassObj_1 {
	public static void main(String[] args) {
HDFCBank h=new HDFCBank();
Scanner s=new Scanner(System.in);
System.out.println("Enter your account number: ");
h.acc_number=s.nextLong();
System.out.println("Enter your name: ");
h.name=s.next();
System.out.println("Enter your operation: ");
String a=s.next();
switch(a) {
case "withdraw":
	System.out.println("Enter withdraw amount: ");
	double amt=s.nextDouble();
	h.withdraw(amt);
	break;
case "deposit":
	System.out.println("Enter deposit amount: ");
	double amt1=s.nextDouble();
	h.deposit(amt1);
	break;
case "check":
	h.check();
	break;
default:
	System.out.println("----- Bank services closed -----");
}
}
}

