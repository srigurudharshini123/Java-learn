		//Save each transaction in file
		//Show transaction histry
import java.io.*;
import java.util.Scanner;

public class File_1 {

	public static void main(String[] args) throws IOException {		

Scanner sc=new Scanner(System.in);
	BufferedWriter bw=new BufferedWriter(new FileWriter("C:\\Users\\ELCOT\\OneDrive\\Documents\\filetask\\Bank.txt",true));
	System.out.println("Enter your option:\n1.Deposit \n2.Withdraw \n3.Checkbalance");
	double balence=40000;
	int option=sc.nextInt();
	if(option==1) {
		System.out.println("Enter amount for Deposit: ");
		double amt=sc.nextDouble();
		balence+=amt;
	    bw.write("Deposit: "+amt+"-> Current Balence: "+balence);
	    bw.newLine();
	}
	else if(option==2) {
		System.out.println("Enter amount for Withdraw: ");
		double amt1=sc.nextDouble();
		if(amt1<=balence) {
		balence-=amt1;
		bw.write("Withdraw: "+amt1+"-> Current Balence: "+balence);
		bw.newLine();
	  }
		else {
			System.out.println("Insufficient Balence");
		}
	}
	else if(option==3) {
		System.out.println("Balance is: "+balence);
	}
	bw.close();
	BufferedReader br=new BufferedReader(new FileReader("C:\\Users\\ELCOT\\OneDrive\\Documents\\filetask\\Bank.txt"));
	String line;
	while((line=br.readLine())!=null){
		System.out.println(line);
	}
		
		
		
	}
}

