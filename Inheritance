//1.In a zoo management system, animals share a behavior such as eating while dogs also bark. Represent this using inheritance.
class Zoo{
		void eat() {
			System.out.println("this animal can eat...");
		}
	}
	class Dog extends Zoo{
		void bark() {
			System.out.println("Dog is barking");
		}
	}
	class Cat extends Zoo{
		void drink() {
			System.out.println("It will drink milk");
		}
	}
public class Inherit_1 {
	public static void main(String[] args) {
Dog d=new Dog();
   d.eat();
   d.bark();
   Cat c=new Cat();
   c.eat();
   c.drink();
}
}

