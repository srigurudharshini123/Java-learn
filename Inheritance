//5.A drawing application defines shapes while circles and rectangles implement their own area calculations.
class Draw{
	void shape(String Shape) {
		System.out.println("your shape is: "+Shape);
	}
}
class Circule extends Draw{
	void Carea(int r) {
		double ans=Math.PI*r*r;
		System.out.println("Area of Circule is: "+ans);
	}
}
class Rectangle extends Circule{
	void Rarea(int l,int b) {
		double ans=l*b;
		System.out.println("Area of Rectangle is: "+ans);
	}
}
class Square extends Rectangle{
	void Sarea(int a) {
		double ans=Math.pow(a, 2);
		System.out.println("Area of Square is: "+ans);
	}
}
public class Inherit_1 {
	public static void main(String[] args) {
Scanner s=new Scanner(System.in);
System.out.println("Enter shape: ");
String shape=s.next();
Square sq=new Square();
sq.shape(shape);
if(shape.equalsIgnoreCase("Circule")) {
	System.out.println("Enter radius: ");
	int r=s.nextInt();
	sq.Carea(r);
}
else if(shape.equalsIgnoreCase("Rectangle")) {
	System.out.println("Enter value of l and b");
	int l=s.nextInt();
	int b=s.nextInt();
	sq.Rarea(l, b);
}
else if(shape.equalsIgnoreCase("Square")) {
	System.out.println("Enter square a: ");
	int a=s.nextInt();
	sq.Sarea(a);
}
else {
	System.out.println("Invalid shape...");
}
}
}

//6.A banking system defines general account behavior while savings and current accounts have specialized features.
class Bank{
	boolean verified=false;
	double balance;
	void verify(long accno,String name) {
		int c=0;
		if(accno==955483902 && name.equalsIgnoreCase("sriguru")) {
			c++;
			verified=true;
		}
		else {
			System.out.println("Invalid data");
		}
		if(c==1) {
			System.out.println("Suceesfully verified your account: ");
		}
	}
}
class Saving extends Bank{
	double bal=50000;
	void checkbal() {
		System.out.println("Your balance is: "+bal);
	}
	void withdraw(double with){
		if(bal>with) {
			bal-=with;
			System.out.println("Wihdraw succesflly....");
			System.out.println("your balance is: "+bal);
	}
		else {
			System.out.println("Insufficient balence");
		}
	}
	void deposit(double depo) {
		bal+=depo;
		System.out.println("Deposit succesfully....");
		System.out.println("Your balance is: "+bal);
	}
	void save() {
		System.out.println("You saved ₹1000");
		bal+=1000;
		System.out.println("Your balance is: "+bal);
	}
}
class Account extends Bank{
	void acc() {
		System.out.println("You have one account...");
	}
}
public class Inherit_1 {
	public static void main(String[] args) {
Saving s=new Saving();
s.verify(955483902l, "sriguru");
if(s.verified) {
s.checkbal();
s.withdraw(10000);
s.deposit(20000);
s.save();
Account a=new Account();
a.acc();
}
}
}

